# ===================================================
# 動画スクレイピング×自動営業フロー
# 環境変数テンプレート
# コピーして .env にリネームし、各値を設定してください
# ===================================================

# --------------------------------------------------
# Google API 認証
# --------------------------------------------------
# Google Cloud Console で作成したサービスアカウントの JSON キーファイルパス
# （Sheets API / Gmail API 両方に対応）
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# Gmail 送信用アカウント（OAuth2 認証の場合はトークンファイルパス）
GMAIL_SENDER_ADDRESS=nari.o.0715.masa.0619@gmail.com
GMAIL_OAUTH_TOKEN_FILE=credentials/gmail_token.json

# --------------------------------------------------
# Google Sheets（ミニ CRM）
# --------------------------------------------------
# Google スプレッドシートの ID（URLの /d/ と /edit の間の文字列）
SPREADSHEET_ID=1rDy0s25zJreMIlmePgT7CNnhOOHDvcue0_RbXdQdhRg

# シート名（デフォルト値。変更した場合は合わせて修正）
SHEET_LEADS=Leads
SHEET_EMAIL_LOG=メール送信ログ
SHEET_MASTER=マスタ設定

GOOGLE_SHEETS_SPREADSHEET_ID=1rDy0s25zJreMIlmePgT7CNnhOOHDvcue0_RbXdQdhRg
GOOGLE_APPLICATION_CREDENTIALS=credentials/service_account.json

# --------------------------------------------------
# Gemini API（メール文生成）
# --------------------------------------------------
# Google AI Studio または Vertex AI で取得した API キー
GEMINI_API_KEY=AIzaSyAkBBOi4yqJnYuqYn6hRqHuCfXt0NmO-qE

# 使用するモデル（デフォルト: gemini-1.5-flash）
GEMINI_MODEL=gemini-2.0-flash

# --------------------------------------------------
# SerpAPI（YouTube チャンネル候補の検索）
# --------------------------------------------------
# https://serpapi.com/ で取得した API キー
# 無料枠: 月100回 / 有料: $50/月〜
SERPAPI_KEY=82f15b3b79a71243db56ef178c4fff2ac0b5fb07afdb748cd4d875d7305f5821

# --------------------------------------------------
# 自社情報（メール署名・送信者名）
# --------------------------------------------------
MY_COMPANY_NAME=株式会社ルヴィラ
MY_NAME=成相 政和
MY_TITLE=マーケティング担当
MY_PHONE=070-5595-9523
MY_WEBSITE=https://luvira.co.jp

# --------------------------------------------------
# 営業メール設定
# --------------------------------------------------
# メールシーケンスの最大通数（デフォルト: 4）
EMAIL_MAX_SEQUENCE=4

# 送信間隔（営業日数）
EMAIL_INTERVAL_DAYS=4

# 1回の実行で送信する最大件数（スパム対策）
EMAIL_MAX_SEND_PER_RUN=20

# 送信対象ランク（カンマ区切り）
EMAIL_TARGET_RANKS=A,B

# --------------------------------------------------
# Flask REST API（n8n / Make 連携用）
# --------------------------------------------------
# Flask の起動ポート
FLASK_PORT=8080

# API 認証トークン（外部連携時の簡易認証）
API_SECRET_TOKEN=change_this_to_a_random_secret

# --------------------------------------------------
# ロギング
# --------------------------------------------------
# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ログファイルの保存パス
LOG_FILE=logs/app.log

# --------------------------------------------------
# スクレイピング設定
# --------------------------------------------------
# リクエスト間の待機時間（秒）。低すぎるとブロックされる
SCRAPE_DELAY_SECONDS=3

# 1回の実行で取得する最大チャンネル数
SCRAPE_MAX_CHANNELS=50


# メール送信設定（Xserver SMTP）
SMTP_HOST=sv16675.xserver.jp
SMTP_PORT=587
SMTP_USER=biz@luvira.co.jp
SMTP_PASSWORD=Mbczb!fUNjDI
MAIL_FROM=biz@luvira.co.jp

